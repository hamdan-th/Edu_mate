rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the user is authenticated with any account (real or anonymous).
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the user is a Firebase Anonymous Auth user.
    // Anonymous users get read-only guest access — no writes allowed.
    function isAnonymous() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Shorthand: authenticated AND not an anonymous guest.
    function isRealUser() {
      return isAuthenticated() && !isAnonymous();
    }

    match /admin_users/{adminUid} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isRealUser();
    }

    match /admin_sessions/{sessionId} {
      allow read, create, update: if isRealUser();
      allow delete: if false;
    }

    match /admin_audit_logs/{logId} {
      allow read, create: if isRealUser();
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();

        match /reactions/{uid} {
          allow read: if isAuthenticated();
          allow create, update, delete: if isRealUser() && request.auth.uid == uid;
        }
      }

      match /typing/{uid} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isRealUser() && request.auth.uid == uid;
      }

      match /pinnedMessages/{messageId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isRealUser();
      }

      match /savedMessages/{userId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();

        match /items/{messageId} {
          allow read: if isAuthenticated();
          allow write: if isRealUser();
        }
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isRealUser()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid']);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();

      match /joined_groups/{docId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();
      }

      match /bot_sessions/{sessionId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();
      }
    }

    match /specializations/{docId} {
      allow read: if isAuthenticated();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();

        match /replies/{replyId} {
          allow read: if isAuthenticated();
          allow write: if isRealUser();
        }
      }
    }

    match /comment_reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /reports/{reportId} {
      allow create: if isRealUser();
      allow read, update, delete: if false;
    }

    match /reports/group_reports/reports/{reportId} {
      allow create: if isRealUser();
      allow read, update, delete: if false;
    }


    match /library_files/{fileId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();

      match /views/{viewUserId} {
        allow read: if isAuthenticated();
        allow write: if isRealUser();
      }
    }

    match /{document=**}/likes/{likeUserId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /{document=**}/saves/{saveUserId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /{document=**}/downloads/{downloadUserId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /{document=**}/shares/{shareUserId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /{document=**}/views/{viewUserId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /digital_saved_references/{docId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /digital_downloads/{docId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /university_files/{fileId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }

    match /university_registry/{identifier} {
      allow get: if true;
      allow list, write: if false;
    }

    match /doctor_verification/{requestId} {
      allow read: if isAuthenticated();
      allow write: if isRealUser();
    }
  }

}
