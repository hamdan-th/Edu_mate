rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    match /admin_users/{adminUid} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    match /admin_sessions/{sessionId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if false;
    }

    match /admin_audit_logs/{logId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    match /groups/{groupId} {
      allow read, write: if isAuthenticated();

      match /members/{memberId} {
        allow read, write: if isAuthenticated();
      }

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();

        match /reactions/{uid} {
          allow read: if isAuthenticated();
          allow create, update, delete: if isAuthenticated() && request.auth.uid == uid;
        }
      }

      match /typing/{uid} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && request.auth.uid == uid;
      }

      match /pinnedMessages/{messageId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated();
      }

      match /savedMessages/{userId} {
        allow read, write: if isAuthenticated();

        match /items/{messageId} {
          allow read, write: if isAuthenticated();
        }
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid']);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated();

      match /joined_groups/{docId} {
        allow read, write: if isAuthenticated();
      }

      match /bot_sessions/{sessionId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /specializations/{docId} {
      allow read: if isAuthenticated();
    }

    match /posts/{postId} {
      allow read, write: if isAuthenticated();

      match /comments/{commentId} {
        allow read, write: if isAuthenticated();

        match /replies/{replyId} {
          allow read, write: if isAuthenticated();
        }
      }
    }

    match /comment_reports/{reportId} {
      allow read, write: if isAuthenticated();
    }

    match /library_files/{fileId} {
      allow read, write: if isAuthenticated();

      match /views/{viewUserId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /{document=**}/likes/{likeUserId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**}/saves/{saveUserId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**}/downloads/{downloadUserId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**}/shares/{shareUserId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**}/views/{viewUserId} {
      allow read, write: if isAuthenticated();
    }

    match /digital_saved_references/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /digital_downloads/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /university_files/{fileId} {
      allow read, write: if isAuthenticated();
    }

    match /doctor_verification/{requestId} {
      allow read, write: if isAuthenticated();
    }
  }
}
